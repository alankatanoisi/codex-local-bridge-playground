{
  "id": "reasoning-replay-tool-loop",
  "description": "Native reasoning item rides along with a function_call and must not disturb the loop (opaque encrypted_content round-trip, reasoning_tokens usage).",
  "prompt": "Read hello.js and tell me what it does.",
  "cwd_files": {
    "hello.js": "console.log('hi');\n"
  },
  "run": {
    "maxSteps": 3,
    "allowedTools": [
      "read_file"
    ]
  },
  "model_script": [
    {
      "output": [
        {
          "type": "reasoning",
          "id": "rs_golden_1",
          "summary": [],
          "encrypted_content": "OPAQUE-FIXTURE-REASONING-BLOB"
        },
        {
          "type": "function_call",
          "call_id": "call_golden_read_1",
          "name": "read_file",
          "arguments": "{\"path\":\"hello.js\"}"
        }
      ],
      "usage": {
        "input_tokens": 60,
        "output_tokens": 25,
        "output_tokens_details": {
          "reasoning_tokens": 17
        }
      }
    },
    {
      "output": [
        {
          "type": "message",
          "role": "assistant",
          "content": [
            {
              "type": "output_text",
              "text": "hello.js logs the string 'hi' to the console."
            }
          ]
        }
      ],
      "usage": {
        "input_tokens": 120,
        "output_tokens": 14
      }
    }
  ],
  "expect": {
    "stopReason": "success",
    "steps": 2,
    "tool_sequence": [
      {
        "name": "read_file",
        "ok": true,
        "permission": {
          "category": "read-only",
          "mode": "default",
          "ruleId": "mode_policy",
          "matchedGuards": [],
          "severity": "bypassable_ask",
          "explanation": "Allowed by current permission mode.",
          "decision": "allow"
        }
      }
    ],
    "stream_event_types": [
      "system",
      "model_request",
      "budget",
      "assistant",
      "tool_use",
      "tool_result",
      "budget",
      "budget",
      "model_request",
      "budget",
      "assistant",
      "result"
    ],
    "trace_event_types": [
      "run_started",
      "runner_context_prepared",
      "runner_model_request_built",
      "budget",
      "runner_model_response_received",
      "tool_requested",
      "tool_finished",
      "budget",
      "budget",
      "runner_model_request_built",
      "budget",
      "runner_model_response_received",
      "run_completed"
    ],
    "files_touched": []
  }
}
