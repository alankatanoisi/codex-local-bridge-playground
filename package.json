{
  "name": "codex-local-bridge-runner",
  "description": "Experimental local coding-agent loop (forked from claude-local-bridge-playground) being ported to OpenAI Codex models via the Responses API, authenticated with a ChatGPT Business programmatic access token from an environment variable",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/alankatanoisi/codex-local-bridge-playground"
  },
  "keywords": [
    "codex",
    "openai",
    "llm",
    "agent",
    "runner",
    "cli"
  ],
  "scripts": {
    "test": "node --require ./test/setup.js --test test/*.test.js test/runner/*.test.js",
    "lint": "eslint --config eslint.config.cjs src/ test/",
    "lint:fix": "eslint --config eslint.config.cjs src/ test/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.js\" \"test/**/*.js\" \"*.json\" \"*.md\"",
    "runner:eval": "node bin/local-bridge-runner.js runner eval",
    "smoke:codex": "node scripts/codex-transport-smoke.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0"
  }
}
